{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "./scripts/update-version.sh ${nextRelease.version} && ./scripts/build-app.sh --arch arm64 && ./scripts/create-dmg.sh --arch arm64 && ./scripts/build-app.sh --arch x86_64 && ./scripts/create-dmg.sh --arch x86_64"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["Info.plist", "CHANGELOG.md", "README.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {"path": "BigDockLocker-apple-silicon-mac.dmg", "label": "Big DockLocker Installer (Apple Silicon) v${nextRelease.version}"},
          {"path": "BigDockLocker-intel-mac.dmg", "label": "Big DockLocker Installer (Intel) v${nextRelease.version}"}
        ]
      }
    ]
  ]
}
